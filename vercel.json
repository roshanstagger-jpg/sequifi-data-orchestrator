{
  "version": 2,
  "framework": null,
  "outputDirectory": "public",
  "functions": {
    "api/index.php": {
      "runtime": "vercel-php@0.7.2",
      "maxDuration": 60
    },
    "api/sequifi.js": {
      "maxDuration": 60
    }
  },
  "routes": [
    { "src": "/sequifi-proxy", "dest": "/api/sequifi.js" },
    { "src": "/(.*)",          "dest": "/api/index.php"  }
  ]
}
